{
  "sap.app": {
    "id": "hypera.conferencia.ui",
    "type": "application",
    "title": "Fluxo de Conferência",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/conference/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "hypera.conferencia.ui.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "synchronizationMode": "None"
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "hypera.conferencia.ui.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "hypera.conferencia.ui.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "name": "login",
          "pattern": "",
          "target": "login"
        },
        {
          "name": "shipments",
          "pattern": "shipments",
          "target": "shipments"
        },
        {
          "name": "conference",
          "pattern": "conference/{shipmentId}",
          "target": "conference"
        }
      ],
      "targets": {
        "login": {
          "viewName": "Login"
        },
        "shipments": {
          "viewName": "ShipmentList"
        },
        "conference": {
          "viewName": "Conference"
        }
      }
    }
  }
}