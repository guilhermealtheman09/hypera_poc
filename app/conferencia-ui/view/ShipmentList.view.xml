<mvc:View
  controllerName="hypera.conferencia.ui.controller.ShipmentList"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  height="100%">

  <Page
    id="shipmentPage"
    title="Remessas"
    showNavButton="false"
    class="hyperaPage hyperaShipmentsPage">

    <!-- HEADER LIMPO -->
    <customHeader>
      <Bar class="hyperaHeader hyperaHeaderTall">
        <contentLeft>
          <Button
            icon="sap-icon://log"
            type="Default"
            press=".onLogout"
            text="Sair"
            class="hyperaHeaderBtn" />
        </contentLeft>

        <contentMiddle>
          <Title text="Remessas" level="H1" class="hyperaHeaderTitle" />
        </contentMiddle>

        <contentRight>
          <HBox />
        </contentRight>
      </Bar>
    </customHeader>

    <content>

      <!-- FILTROS -->
      <VBox class="hyperaFiltersBlock">

        <HBox wrap="Wrap" class="hyperaFiltersRow">

          <VBox class="hyperaFilterField">
            <Text text="DOCA" class="hyperaFilterLabel"/>
            <Select id="dockSelect" class="hyperaFilterSelect" width="100%"/>
          </VBox>

          <VBox class="hyperaFilterField">
            <Text text="TRANSPORTADORA" class="hyperaFilterLabel"/>
            <Select id="carrierSelect" class="hyperaFilterSelect" width="100%"/>
          </VBox>

        </HBox>

      </VBox>

      <!-- CHIPS -->
      <ScrollContainer
        horizontal="true"
        vertical="false"
        class="hyperaChipsScroll"
        width="100%">

        <HBox class="hyperaChipsRow">

          <Button text="Todas"         press=".onChipPress" class="hyperaChip hyperaChipActive"/>
          <Button text="Pendentes"     press=".onChipPress" class="hyperaChip"/>
          <Button text="Em andamento"  press=".onChipPress" class="hyperaChip"/>
          <Button text="Aprovadas"     press=".onChipPress" class="hyperaChip"/>
          <Button text="Divergentes"   press=".onChipPress" class="hyperaChip"/>
          <Button text="Caixa a caixa" press=".onChipPress" class="hyperaChip"/>

        </HBox>

      </ScrollContainer>

      <!-- BUSCA -->
      <VBox class="hyperaFiltersBlock">
        <SearchField
          id="searchField"
          width="100%"
          placeholder="Buscar remessa, produto, doca..."
          liveChange=".onSearch"
          search=".onSearch"
          class="hyperaSearchField"/>
      </VBox>

      <!-- LISTA -->
      <List
        id="shipmentList"
        items="{/Shipments}"
        growing="true"
        growingScrollToLoad="true"
        noDataText="Nenhuma remessa encontrada"
        class="hyperaList">

        <CustomListItem
          type="Active"
          press=".onItemPress"
          class="hyperaListItem">

          <HBox
            alignItems="Center"
            justifyContent="SpaceBetween"
            class="hyperaItemRow"
            wrap="Wrap">

            <!-- ESQUERDA -->
            <VBox class="hyperaItemMain">

              <HBox alignItems="Center" wrap="Wrap">
                <Text text="{shipmentNumber}" class="hyperaItemNumber"/>

                <ObjectStatus
                  text="{status}"
                  class="hyperaStatusChip sapUiTinyMarginBegin"/>
              </HBox>

              <Text text="{product}" class="hyperaItemProduct"/>

              <HBox class="hyperaItemMeta" wrap="Wrap">
                <Text text="{dock}" class="hyperaItemMetaText"/>
                <Text text=" • " class="hyperaItemMetaSep"/>
                <Text text="{carrier}" class="hyperaItemMetaText"/>
                <Text text=" • " class="hyperaItemMetaSep"/>
                <Text text="{destination}" class="hyperaItemMetaText"/>
              </HBox>

            </VBox>

            <!-- DIREITA -->
            <VBox class="hyperaItemQty" alignItems="End">

              <Text text="Esperado / Contado" class="hyperaItemQtyLabel"/>

              <Text
                text="{
                  parts: ['countedQuantity','expectedQuantity'],
                  formatter: '.formatter.progressText'
                }"
                class="hyperaItemQtyText"/>

            </VBox>

          </HBox>

        </CustomListItem>

      </List>

    </content>

    <!-- FOOTER -->
    <footer>
      <Toolbar class="hyperaFooterBar">
        <Text text="Total: {/Shipments}.length remessas" class="hyperaFooterText"/>
        <ToolbarSpacer/>
      </Toolbar>
    </footer>

  </Page>
</mvc:View>